# ===========================
# HK-FinReg AI PoC (Fintech) — 環境變量模板
# ===========================
# 複製此文件為 .env 並填入真實值：
#   cp .env.example .env

# ----- DashScope (通義千問，遺留/可選) -----
DASHSCOPE_API_KEY=your_dashscope_api_key

# ----- 智譜 GLM (主要 LLM + Embedding) -----
# 註冊：https://open.bigmodel.cn
ZHIPU_API_KEY=your_zhipu_api_key

# ----- LongCat (深度思考引擎) -----
# 註冊：https://api.longcat.chat
LONGCAT_API_KEY=your_longcat_api_key

# ----- LangSmith 全鏈路追蹤 -----
# 註冊：https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_api_key
LANGCHAIN_PROJECT=Fintech-PoC-Backend
