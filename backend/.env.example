# ===========================
# HK-FinReg AI Backend — 環境變量模板
# ===========================
# 複製此文件為 .env 並填入真實值：
#   cp .env.example .env

# ----- LLM API Keys -----
ZHIPU_API_KEY=your_zhipu_api_key
LONGCAT_API_KEY=your_longcat_api_key

# ----- Cohere Reranker -----
# 註冊：https://dashboard.cohere.com/api-keys
COHERE_API_KEY=your_cohere_api_key

# ----- LangSmith 全鏈路追蹤 -----
# 註冊：https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_api_key
LANGCHAIN_PROJECT=Fintech-PoC-Backend

# ----- Security (可選) -----
# 設為 True 並配置 API_KEY 後，所有業務端點需攜帶 Authorization: Bearer <key>
API_KEY_ENABLED=False
API_KEY=your_secret_api_key

# ----- App Mode -----
# 設為 True 開啟 Swagger 文檔 (/docs, /redoc) 和測試客戶端 (/test)
DEBUG=False

