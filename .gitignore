# ===========================
# HK-FinReg AI — Root .gitignore
# ===========================

# ----- Environment Variables (CRITICAL — never commit real keys) -----
.env
.env.*
!.env.example
Fintech/.env
backend/.env
frontend/.env.local

# ----- Secrets & Private Keys -----
*.pem
*.key
*.p12
*.pfx
*.jks
*.keystore
*_rsa
*_dsa
*_ecdsa
*_ed25519
*.secret

# ----- Python -----
__pycache__/
*/__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.pyo
*.egg-info/
*.egg

# ----- Virtual Environments -----
HKFinReg/
venv/
.venv/
env/

# ----- Node.js -----
node_modules/
.next/
out/

# ----- ChromaDB local storage -----
chroma_data/
**/chroma_data/

# ----- IDE / OS -----
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*.swo
*~

# ----- AI Assistant Files -----
.gemini/
.claude/
CLAUDE.md

# ----- Logs -----
*.log
logs/
Fintech/compliance_audit.log

# ----- Temporary test scripts -----
test.py
test2.py
Fintech/test.py
Fintech/test2.py

# ----- Build artifacts -----
dist/
build/
.vercel
coverage/
.coverage
htmlcov/

